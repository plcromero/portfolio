# --- Site ---
NEXT_PUBLIC_SITE_URL=https://plcromero.es
# (opcional) verificación de Google Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- SMTP del formulario de contacto ---
# Datos típicos de Plesk para metalendario.es:
SMTP_HOST=mail.metalendario.es
SMTP_PORT=465
SMTP_USER=soporte@metalendario.es
SMTP_PASS=cambia-esto-por-tu-password-smtp

# Remitente que verá el destinatario.
# Importante: el dominio del FROM debe pertenecer a la cuenta SMTP o tener SPF/DKIM correctos.
MAIL_FROM="plcromero <soporte@metalendario.es>"

# A quién llega la notificación cuando alguien envía el formulario:
OWNER_EMAIL=plcromero@gmail.com

# Reply-To para la auto-respuesta al usuario (si responden, te llega a ti):
MAIL_REPLY_TO=plcromero@gmail.com
